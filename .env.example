# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Dadata API (для автозаполнения по ИНН)
# 1. Зарегистрируйтесь на https://dadata.ru
# 2. Получите API ключ в личном кабинете
# 3. Бесплатно до 10 000 запросов в день
#VITE_DADATA_API_KEY=

# OpenRouter API (для AI обработки райдеров)
# ⚠️ ВАЖНО: Ключ хранится в Supabase Edge Function, не в браузере!
# 
# Настройка:
# 1. Зарегистрируйтесь на https://openrouter.ai
# 2. Создайте API ключ (начинается с sk-or-...)
# 3. Добавьте ключ в Supabase Dashboard → Edge Functions → Environment Variables
# 4. Деплой функции: см. supabase/functions/parse-rider/README.md
#
# Переменная ниже нужна только если будете тестировать функцию локально
# VITE_OPENROUTER_API_KEY=sk-or-v1-...
