# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Dadata API (для автозаполнения по ИНН)
# 1. Зарегистрируйтесь на https://dadata.ru
# 2. Получите API ключ в личном кабинете
# 3. Бесплатно до 10 000 запросов в день
#VITE_DADATA_API_KEY=

# GigaChat API (для AI обработки райдеров)
# ⚠️ ВАЖНО: Ключи хранятся в Supabase Edge Function, не в браузере!
# 
# Настройка:
# 1. Зарегистрируйтесь на https://developers.sber.ru
# 2. Создайте проект и получите Client ID и Client Secret  
# 3. Деплой функции: см. supabase/functions/parse-rider/README.md
#
# Для локальной разработки (если нужно):
# VITE_GIGACHAT_CLIENT_ID=your_id
# VITE_GIGACHAT_CLIENT_SECRET=your_secret
