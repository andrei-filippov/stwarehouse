# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Dadata API (для автозаполнения по ИНН)
# 1. Зарегистрируйтесь на https://dadata.ru
# 2. Получите API ключ в личном кабинете
# 3. Бесплатно до 10 000 запросов в день
#VITE_DADATA_API_KEY=

# Yandex Disk OAuth (для хранения файлов)
# 1. Создайте приложение на https://oauth.yandex.ru/
# 2. Укажите Callback URL: https://your-domain.com
# 3. Скопируйте Client ID
#VITE_YANDEX_CLIENT_ID=your_yandex_client_id
